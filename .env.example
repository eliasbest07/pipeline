# ── LLM (Anthropic) ────────────────────────────────────────────
# Requerido para agentes de texto (AG-00 a AG-07)
ANTHROPIC_API_KEY=sk-ant-...

# Modelo a usar por defecto para los agentes de texto
# Opciones: claude-opus-4-6 | claude-sonnet-4-6 | claude-haiku-4-5-20251001
ANTHROPIC_MODEL=claude-sonnet-4-6

# ── Media Generation (fal.ai) ───────────────────────────────────
# Requerido para AG-04 (imágenes), video y audio
FAL_KEY=

OPENAI_API_KEY=

GOOGLE_API_KEY=

# ── Skills ──────────────────────────────────────────────────────
# SKL-01 Web Search (elige uno)
BRAVE_API_KEY=
SERPER_API_KEY=
# Si ninguno está configurado, usa DuckDuckGo como fallback (sin key)

# ── Servidor ────────────────────────────────────────────────────
PORT=3000
